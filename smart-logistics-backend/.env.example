# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/intelliship?retryWrites=true&w=majority

# JWT Secret Key - MUST be changed in production
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

# Environment
NODE_ENV=production

# CORS Configuration - comma-separated list of allowed origins
# For production, specify your frontend domain(s)
ALLOWED_ORIGINS=https://intelli-ship-project-frontend.vercel.app

# Optional: Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT=100

# JWT expiry (example: 12h, 7d)
JWT_EXPIRES_IN=12h

# Frontend base URL used in tracking links and QR
FRONTEND_BASE_URL=https://intelli-ship-project-frontend.vercel.app

# ML microservice endpoint
ML_SERVICE_URL=https://intelliship-ml-service.onrender.com

# Number of HIGH severity events required to auto-mark a shipment as damaged
HIGH_EVENT_DAMAGE_THRESHOLD=3
